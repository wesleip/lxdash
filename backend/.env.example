# =============================================================================
# lxdash backend — environment configuration
# Copy this file to .env and fill in real values. Never commit .env to git.
# =============================================================================

# -------------------------------------------------------------------
# Database
# SQLite for local development; swap to postgres:// for production.
# -------------------------------------------------------------------
DATABASE_URL=sqlite:///./lxdash.db
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/lxdash

# -------------------------------------------------------------------
# JWT / Auth
# Generate SECRET_KEY with: openssl rand -hex 32
# -------------------------------------------------------------------
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
ALGORITHM=HS256

# Access token lifetime in minutes (default: 15)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh token lifetime in days (default: 7)
REFRESH_TOKEN_EXPIRE_DAYS=7

# -------------------------------------------------------------------
# LXD
# Path to the local LXD Unix socket. Ignored when connecting via TLS.
# -------------------------------------------------------------------
LXD_SOCKET_PATH=/var/snap/lxd/common/lxd/unix.socket

# -------------------------------------------------------------------
# CORS
# JSON array of allowed origins (pydantic-settings requires JSON for list fields).
# -------------------------------------------------------------------
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# -------------------------------------------------------------------
# Application
# -------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
